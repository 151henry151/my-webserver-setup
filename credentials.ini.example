# Gandi.net API Credentials
# API documentation: https://api.gandi.net/docs/authentication/
# Test a token: curl -H "Authorization: Bearer <TOKEN>" https://id.gandi.net/tokeninfo

[gandi.net]
# Personal Access Tokens (PAT)
# First PAT
pat1 = YOUR_GANDI_PAT_1_HERE
# Second PAT
pat2 = YOUR_GANDI_PAT_2_HERE

# Cloudflare API Credentials
# API documentation: https://developers.cloudflare.com/fundamentals/api/
# Test a token:
# curl -X GET "https://api.cloudflare.com/client/v4/user/tokens/verify" \
#      -H "Authorization: Bearer <TOKEN>" \
#      -H "Content-Type:application/json"

[cloudflare]
# API Token
api_token = YOUR_CLOUDFLARE_API_TOKEN_HERE

# Interserver API Credentials
# Example usage: https://github.com/detain/interserver-api-python-samples
# (No official documentation found; see above for Python usage samples)

[interserver]
# API Token
api_token = YOUR_INTERSERVER_API_TOKEN_HERE

# GitHub API Credentials
# API documentation: https://docs.github.com/en/rest/authentication/authenticating-to-the-rest-api?apiVersion=2022-11-28#basic-authentication
# Test a token:
# curl --request GET \
# --url "https://api.github.com/octocat" \
# --header "Authorization: Bearer <TOKEN>" \
# --header "X-GitHub-Api-Version: 2022-11-28"

[github]
# Personal Access Token (PAT)
api_token = YOUR_GITHUB_PAT_HERE

# Google Cloud Console API Key
# API documentation: https://cloud.google.com/docs/authentication/api-keys

[google_cloud]
# API Key
api_key = YOUR_GOOGLE_CLOUD_API_KEY_HERE

# INSTRUCTIONS:
# 1. Copy this file to credentials.ini
# 2. Fill in your own API tokens and PATs in place of the placeholders above.
# 3. Keep credentials.ini secure and never commit it to version control. 